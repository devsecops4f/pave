# PAVE Environment Variables
# Copy this file to .env and fill in the values

# LLM Provider Configuration
UTU_LLM_TYPE=chat.completions
UTU_LLM_MODEL=<your-model>
UTU_LLM_BASE_URL=<your-api-base-url>
UTU_LLM_API_KEY=<your-api-key>

LLM_EVAL_DB_URL=""

# Path to the ops-lite dataset snapshot (must contain manifest.jsonl + cases/).
# Pull once with:
#   hf download anon-ops/ops-lite --repo-type dataset --local-dir ./data/ops_lite
# Then point this at that directory.
OPS_LITE_ROOT=./data/ops_lite
